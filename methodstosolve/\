void solve() {
  // cin.ignore(numeric_limits<streamsize>::max(), '\n');
  int n;
  cin >> n;

  string s;
  cin >> s;

  int initial_ones = 0;
  vi one_indexes;
  for (int i = 0; i < n; ++i) {
    if (s[i] == '1') {
      initial_ones++;
      one_indexes.push_back(i);
    }
  }

  if (n == 1 && initial_ones == 0) {
    cout << 1 << "\n";
    return;
  }

  for (const auto &index : one_indexes) {
    if (index > 0 && index < n - 1) {
      s[index - 1] = '1';
      s[index + 1] = '1';
    } else if (index == 0) {
      s[index + 1] = '1';
    } else {
      s[index - 1] = '1';
    }
  }

  int new_ones = 0;
  int left = 0;

  for (int right = 0; right < n; ++right) {
    if (s[right] != '0') {
      new_ones += (right - left) / 2;
      left = right + 1;
    }
  }

  if (left != n - 1) {
    new_ones += (n - left) / 2;
  }

  cout << initial_ones + new_ones << "\n";
}

